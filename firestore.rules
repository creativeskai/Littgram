rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    match /users/{userId}/{document=**} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    match /books/{bookId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /chunks/{chunkId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
      match /readers/{uid} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null && request.auth.uid == uid;
      }
    }

    match /challenges/{challengeId} {
      allow read: if true;
      allow write: if request.auth != null;
      match /members/{memberId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    match /community_posts/{postId} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /readers/{handle} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /follows/{handle}/{document=**} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    match /meta/{doc} {
      allow read: if true;
      allow write: if request.auth != null;
    }

    // Web-push subscriptions. Public read is deliberate: the daily push
    // cron (api/push-daily.js) runs without Firebase credentials, and a
    // subscription is only usable with our VAPID private key anyway.
    match /push_subs/{handle} {
      allow read: if true;
      allow write, delete: if request.auth != null;
    }
  }
}
